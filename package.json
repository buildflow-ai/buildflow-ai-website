{
  "name": "buildflow-ai-final",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "install:ci": "bash scripts/install-ci.sh",
    "dev": "vite",
    "build": "vinext build",
    "start": "vinext start",
    "test": "npm run build && node --test tests/rendered-html.test.mjs",
    "validate:artifact": "node -e \"const f=require('fs');if(!f.existsSync('dist/server/index.js')||!f.existsSync('dist/.openai/hosting.json'))process.exit(1)\"",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply buildflow-ai-leads --local",
    "db:migrate:remote": "wrangler d1 migrations apply buildflow-ai-leads --remote",
    "db:export": "wrangler d1 execute buildflow-ai-leads --remote --command \"SELECT * FROM workflow_submissions ORDER BY created_at DESC\" --json",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run test",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@cloudflare/workers-types": "^5.20260714.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "^4.110.0"
  },
  "type": "module",
  "displayName": "BuildFlow AI"
}
